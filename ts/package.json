{
  "name": "colab-mcp-ts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TypeScript port of the Colab MCP server — bridges an AI client (stdio) to a live Google Colab tab over a localhost WebSocket. Spike.",
  "bin": {
    "colab-mcp": "dist/index.mjs"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=esm --outfile=dist/index.mjs --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
    "start": "node dist/index.mjs",
    "dev": "npm run build && node dist/index.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
